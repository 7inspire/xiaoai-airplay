# 小米账号认证（二选一）
# 方式1: userId + passToken（推荐，从浏览器抓包获取）
MI_USER=2608020621
MI_PASS=V1:xxxx...your_pass_token...xxxx

# 方式2: 手机号 + 密码
# MI_USER=13800138000
# MI_PASS=your_password

# 可选：指定设备 DID（多个音箱时使用）
# MI_DID=b87d6384-3f82-4cd8-a883-bbc2f31166b7

# 宿主机 IP（NAS 使用 network_mode: host 时可不填，自动检测）
# 非 host 网络模式时必填（音箱需要通过此 IP 访问音频流）
# HOST_IP=192.168.1.100
